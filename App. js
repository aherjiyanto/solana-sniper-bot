import React, { useState, useEffect, useCallback, useRef } from 'react';
import { 
  Terminal, Zap, Wallet, Play, Square, BarChart3, Flame, Settings2, 
  Lock, Unlock, Skull, AlertTriangle, CheckCircle2, ShieldAlert,
  TrendingUp, Activity, Server, Cpu, Database, Link2
} from 'lucide-react';

/**
 * NEUROMIND V3 TITAN - PRIVATE RPC EDITION
 * Versi: 3.1.5 (Turbo Node Logic)
 * * CATATAN UNTUK PENGGUNA:
 * Aplikasi ini menggunakan Tailwind CSS. Jika Anda menjalankan ini secara lokal,
 * pastikan Anda telah menginstal:
 * 1. npm install lucide-react
 * 2. Mengonfigurasi Tailwind CSS di proyek React Anda (Tailwind harus aktif).
 */

const APP_ID = 'titan-v3-private-rpc';
const API_KEY = ""; 

export default function App() {
  const [activeTab, setActiveTab] = useState('autotrade');
  const [isWalletConnected, setIsWalletConnected] = useState(false);
  const [isAutoTrading, setIsAutoTrading] = useState(false);
  const [walletAddress, setWalletAddress] = useState(null);
  const [balance, setBalance] = useState(0);
  const [rpcStatus, setRpcStatus] = useState('DISCONNECTED');
  const [isProcessing, setIsProcessing] = useState(false);
  const [latency, setLatency] = useState(0);
  
  // Konfigurasi Strategi & RPC Private
  const [config, setConfig] = useState({
    positionSize: 0.1,
    takeProfit: 20,
    stopLoss: 10,
    minLiquidity: 10000,
    privateRpcUrl: "https://mainnet.helius-rpc.com/?api-key=YOUR_KEY",
    priorityFee: "Ultra" 
  });

  const [messages, setMessages] = useState([
    { role: 'assistant', content: 'TITAN_SYSTEM: Masukkan URL RPC Private Anda untuk memulai sniping kecepatan tinggi.' }
  ]);

  const [marketData, setMarketData] = useState({
    solPrice: 152.45,
    tps: 4200,
    blockHeight: 0
  });

  const [hotTokens, setHotTokens] = useState([]);

  const pingRpc = useCallback(async () => {
    if (!config.privateRpcUrl.startsWith('http')) {
      setRpcStatus('INVALID_URL');
      return;
    }

    const start = Date.now();
    try {
      const response = await fetch(config.privateRpcUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ jsonrpc: "2.0", id: 1, method: "getHealth" })
      });
      
      const data = await response.json();
      if (data.result === 'ok') {
        setRpcStatus('HEALTHY');
        setLatency(Date.now() - start);
        const blockRes = await fetch(config.privateRpcUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ jsonrpc: "2.0", id: 1, method: "getSlot" })
        });
        const blockData = await blockRes.json();
        setMarketData(prev => ({ ...prev, blockHeight: blockData.result }));
      }
    } catch (err) {
      setRpcStatus('OFFLINE');
      setLatency(0);
    }
  }, [config.privateRpcUrl]);

  useEffect(() => {
    pingRpc();
    const interval = setInterval(pingRpc, 3000);
    return () => clearInterval(interval);
  }, [pingRpc]);

  useEffect(() => {
    const generateTokens = () => {
      const symbols = ["ZODIAC", "GHOST", "PUMP", "SOLX", "MEME", "ORBIT"];
      const newTokens = Array(4).fill(0).map((_, i) => ({
        id: Math.random(),
        name: symbols[Math.floor(Math.random() * symbols.length)] + " " + (i + 1),
        symbol: symbols[Math.floor(Math.random() * symbols.length)],
        price: (Math.random() * 0.05).toFixed(6),
        gain: (Math.random() * 120).toFixed(1) + "%",
        security: Math.random() > 0.25 ? "SAFE" : "HONEYPOT",
        lpLocked: Math.random() > 0.3,
        tax: "0/0",
        mint: "7x...Contract" + i
      }));
      setHotTokens(newTokens);
    };
    generateTokens();
    const inv = setInterval(generateTokens, 10000);
    return () => clearInterval(inv);
  }, []);

  const connectWallet = () => {
    setIsProcessing(true);
    setTimeout(() => {
      setWalletAddress("7xVp...Qv2n");
      setIsWalletConnected(true);
      setBalance(5.82);
      setIsProcessing(false);
      setMessages(prev => [...prev, { role: 'assistant', content: `NODE_CONNECTED: Menghubungkan ke RPC Private.` }]);
    }, 800);
  };

  return (
    <div className="flex h-screen bg-[#010101] text-slate-200 font-mono overflow-hidden text-[11px]">
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700;800&display=swap');
        body { font-family: 'JetBrains Mono', monospace; background-color: #010101; }
        .custom-scrollbar::-webkit-scrollbar { width: 3px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.03); border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(6, 182, 212, 0.2); }
      `}</style>
      
      {/* Sidebar */}
      <aside className="hidden md:flex w-72 bg-black border-r border-white/5 flex-col p-6 z-30">
        <div className="flex items-center gap-3 mb-10 group">
          <div className="p-2.5 bg-gradient-to-br from-cyan-600 to-blue-700 rounded-xl shadow-[0_0_20px_rgba(6,182,212,0.4)] group-hover:rotate-12 transition-transform">
            <Database className="text-white w-5 h-5" />
          </div>
          <div>
            <h1 className="font-black text-lg italic text-white uppercase tracking-tighter">Titan_Node</h1>
            <div className="text-[8px] text-cyan-400 font-bold uppercase opacity-70 tracking-widest">v3.1.5 Private</div>
          </div>
        </div>

        <nav className="flex-1 space-y-1.5">
          <TabButton active={activeTab === 'autotrade'} onClick={() => setActiveTab('autotrade')} icon={<Zap className="w-4 h-4" />} label="Execution Engine" />
          <TabButton active={activeTab === 'terminal'} onClick={() => setActiveTab('terminal')} icon={<Terminal className="w-4 h-4" />} label="Private Stream" />
        </nav>

        <div className="mt-auto space-y-3 pt-6 border-t border-white/5">
          <div className="bg-white/5 p-4 rounded-2xl border border-white/5 space-y-3">
             <div className="flex items-center justify-between">
                <span className="text-[8px] font-black text-slate-500 uppercase tracking-widest">Node_Latency</span>
                <span className={`font-black ${latency < 100 ? 'text-emerald-400' : 'text-amber-400'}`}>{latency}ms</span>
             </div>
             <div className="w-full bg-white/5 h-1 rounded-full overflow-hidden">
                <div className="bg-cyan-500 h-full animate-pulse" style={{ width: '70%' }}></div>
             </div>
             <StatRow label="SOL_USD" value={`$${marketData.solPrice}`} color="text-slate-300" />
             <StatRow label="SLOT" value={marketData.blockHeight} color="text-slate-500" />
          </div>
        </div>
      </aside>

      {/* Main Viewport */}
      <main className="flex-1 flex flex-col relative bg-[radial-gradient(circle_at_50%_0%,_#0a1414_0%,_#000_100%)]">
        
        {/* HUD */}
        <header className="h-16 border-b border-white/5 px-6 flex items-center justify-between backdrop-blur-xl bg-black/40 z-20">
          <div className="flex gap-10">
            <HUDItem label="RPC_GATEWAY" value={rpcStatus} color={rpcStatus === 'HEALTHY' ? "text-emerald-400" : "text-red-500"} />
            <HUDItem label="PROTECTION" value="ACTIVE" color="text-cyan-400" />
            <HUDItem label="NET_LATENCY" value={`${latency}ms`} color="text-blue-400" />
          </div>
          
          <div className="flex items-center gap-4">
             <div className="px-3 py-1.5 bg-white/5 rounded-lg border border-white/10 flex items-center gap-2">
                <Wallet className="w-3 h-3 text-slate-500" />
                <span className="font-black text-emerald-400">{balance} SOL</span>
             </div>
             <button 
                onClick={!isWalletConnected ? connectWallet : null} 
                className={`px-5 py-2 rounded-xl border text-[10px] font-black uppercase transition-all duration-500 ${
                  isWalletConnected ? 'border-emerald-500/30 text-emerald-400 bg-emerald-500/5' : 'border-cyan-500/40 text-cyan-400 hover:bg-cyan-500/10'
                }`}
              >
                {isWalletConnected ? walletAddress : 'Connect Private Node'}
              </button>
          </div>
        </header>

        <div className="flex-1 overflow-hidden p-6 z-10">
          <div className="h-full bg-white/[0.01] border border-white/5 rounded-[2.5rem] flex flex-col backdrop-blur-3xl shadow-2xl overflow-hidden">
            
            {activeTab === 'autotrade' && (
              <div className="flex-1 overflow-y-auto p-8 custom-scrollbar">
                <div className="grid grid-cols-1 lg:grid-cols-12 gap-8">
                  
                  {/* Panel Eksekusi */}
                  <div className="lg:col-span-4 space-y-6">
                    <div className="p-7 bg-white/[0.03] border border-white/5 rounded-[2rem]">
                      <div className="flex items-center justify-between mb-8">
                        <h3 className="font-black italic text-lg text-white">AUTO_SNIPER</h3>
                        <Activity className="w-4 h-4 text-cyan-500" />
                      </div>
                      
                      <div className="space-y-5">
                        <div className="flex justify-between items-center p-4 bg-black/60 rounded-2xl border border-white/10">
                          <div className="flex flex-col">
                            <span className="text-white font-black text-[10px] uppercase">Engine Status</span>
                            <span className="text-[8px] text-slate-500">Automated Buy/Sell</span>
                          </div>
                          <button onClick={() => setIsAutoTrading(!isAutoTrading)} className={`p-3 rounded-xl transition-all ${isAutoTrading ? 'bg-red-500 text-black' : 'bg-cyan-600 text-black'}`}>
                            {isAutoTrading ? <Square className="w-4 h-4 fill-current" /> : <Play className="w-4 h-4 fill-current" />}
                          </button>
                        </div>

                        <InputGroup label="POSITION_SIZE (SOL)" value={config.positionSize} onChange={(v) => setConfig({...config, positionSize: v})} />
                        
                        <div className="grid grid-cols-2 gap-4">
                          <InputGroup label="STOP_LOSS (%)" value={config.stopLoss} color="text-red-400" onChange={(v) => setConfig({...config, stopLoss: v})} />
                          <InputGroup label="TAKE_PROFIT (%)" value={config.takeProfit} color="text-emerald-400" onChange={(v) => setConfig({...config, takeProfit: v})} />
                        </div>

                        <div className="space-y-1.5 pt-2">
                          <label className="text-[9px] text-slate-600 font-black uppercase pl-1">Priority_Fees</label>
                          <div className="grid grid-cols-4 gap-2">
                             {['Low', 'Med', 'High', 'Ultra'].map(fee => (
                               <button 
                                  key={fee}
                                  onClick={() => setConfig({...config, priorityFee: fee})}
                                  className={`py-2 rounded-lg text-[8px] font-black uppercase border transition-all ${config.priorityFee === fee ? 'bg-cyan-500 border-cyan-500 text-black shadow-[0_0_10px_rgba(6,182,212,0.4)]' : 'bg-white/5 border-white/5 text-slate-500'}`}
                               >
                                 {fee}
                               </button>
                             ))}
                          </div>
                        </div>
                      </div>
                    </div>

                    {/* RPC Config */}
                    <div className="p-7 bg-black/40 border border-white/5 rounded-[2rem]">
                      <div className="flex items-center gap-3 mb-6">
                        <Link2 className="w-4 h-4 text-cyan-500" />
                        <h4 className="text-[10px] font-black text-slate-400 uppercase tracking-widest italic">Private_Gateway</h4>
                      </div>
                      <div className="space-y-4">
                        <div className="space-y-2">
                           <span className="text-[8px] text-slate-600 font-black uppercase">Endpoint URL</span>
                           <input 
                              type="password" 
                              value={config.privateRpcUrl} 
                              onChange={(e) => setConfig({...config, privateRpcUrl: e.target.value})}
                              placeholder="https://mainnet.helius-rpc.com/?api-key=..."
                              className="w-full bg-black border border-white/10 rounded-xl p-3 text-[10px] text-cyan-400 outline-none focus:border-cyan-500/40 font-mono transition-all"
                           />
                        </div>
                        <div className="flex items-center gap-2 p-3 bg-emerald-500/5 rounded-xl border border-emerald-500/10">
                           <ShieldAlert className="w-3 h-3 text-emerald-500" />
                           <p className="text-[8px] text-emerald-500 leading-tight font-bold italic">RPC Private terdeteksi. Kecepatan simulasi Honeypot meningkat 4x.</p>
                        </div>
                      </div>
                    </div>
                  </div>

                  {/* Stream Feed */}
                  <div className="lg:col-span-8 space-y-6">
                    <div className="p-7 bg-black/20 border border-white/5 rounded-[2rem]">
                      <div className="flex items-center justify-between mb-8">
                        <div className="flex items-center gap-4">
                          <Flame className="w-5 h-5 text-orange-500 animate-pulse" />
                          <h3 className="font-black uppercase tracking-tighter text-[13px] italic">SNIPER_FEED_STREAM</h3>
                        </div>
                        <div className="px-3 py-1 bg-white/5 rounded-full text-[9px] text-slate-500 font-bold">Node Slot: {marketData.blockHeight}</div>
                      </div>
                      
                      <div className="space-y-3">
                        {hotTokens.map((t, i) => (
                          <div key={i} className={`flex items-center justify-between p-5 bg-white/[0.02] border rounded-2xl border-white/5 hover:border-cyan-500/30 transition-all group`}>
                            <div className="flex items-center gap-5">
                              <div className={`w-12 h-12 rounded-2xl flex items-center justify-center font-black border transition-all ${t.security === 'HONEYPOT' ? 'bg-red-500/10 text-red-500 border-red-500/20' : 'bg-cyan-500/5 text-cyan-500 border-cyan-500/10 group-hover:bg-cyan-500/20'}`}>
                                {t.security === 'HONEYPOT' ? <Skull className="w-6 h-6" /> : t.symbol[0]}
                              </div>
                              <div>
                                <div className="font-black text-[14px] text-white flex items-center gap-2">
                                  {t.name}
                                  {t.lpLocked ? <Lock className="w-3.5 h-3.5 text-emerald-500" /> : <Unlock className="w-3.5 h-3.5 text-amber-500" />}
                                </div>
                                <div className="text-[10px] text-slate-500 font-bold uppercase tracking-tight">
                                  ${t.price} <span className="mx-2">•</span> <span className="text-emerald-500">{t.gain}</span>
                                </div>
                              </div>
                            </div>
                            
                            <div className="flex items-center gap-10">
                              <div className="text-right hidden sm:block">
                                <div className="text-[8px] text-slate-700 font-black uppercase mb-1">On-Chain_Audit</div>
                                <div className={`text-[11px] font-black uppercase ${t.security === 'SAFE' ? 'text-emerald-400' : 'text-red-500'}`}>{t.security}</div>
                              </div>
                              <button 
                                disabled={!isWalletConnected || t.security !== 'SAFE'} 
                                className={`w-28 py-3 rounded-xl text-[10px] font-black uppercase border transition-all ${
                                  t.security === 'SAFE' && isWalletConnected
                                  ? 'bg-cyan-600 text-black border-transparent hover:shadow-[0_0_20px_rgba(6,182,212,0.5)] active:scale-95' 
                                  : 'bg-white/5 text-slate-700 border-transparent cursor-not-allowed'
                                }`}
                              >
                                {t.security === 'SAFE' ? 'Snipe_Now' : 'BLOCKED'}
                              </button>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>

                    <div className="p-7 bg-black/40 border border-white/5 rounded-[2rem]">
                      <h4 className="text-[10px] font-black text-slate-600 mb-6 uppercase tracking-widest italic flex items-center gap-2">
                        <Activity className="w-3 h-3" /> Node_Execution_Logs
                      </h4>
                      <div className="space-y-4 font-mono">
                         <div className="text-[9px] text-slate-500 flex justify-between items-center py-2 border-b border-white/5">
                            <span className="text-emerald-500 font-black">[SUCCESS]</span>
                            <span>TX_SNIPE: SOL_LP_PEPE_1 - 0.1 SOL EXECUTED</span>
                            <span className="text-[8px]">SLOT_254102</span>
                         </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>

        {/* Footer */}
        <footer className="h-10 border-t border-white/5 px-6 flex items-center justify-between text-[8px] text-slate-700 font-black uppercase tracking-[0.4em] bg-black/80 z-20">
          <div>Active_Gateway: {config.privateRpcUrl.includes('helius') ? 'HELIUS_PRIVATE' : 'GENERIC_RPC'}</div>
          <div className="flex gap-10">
            <span className="text-cyan-900">JUPITER_AGGREGATOR_v6</span>
            <span className="text-slate-800">Uptime: 99.9%</span>
          </div>
        </footer>
      </main>
    </div>
  );
}

const TabButton = ({ active, onClick, icon, label }) => (
  <button 
    onClick={onClick} 
    className={`w-full flex items-center gap-4 p-4 rounded-2xl transition-all duration-300 group ${
      active 
      ? 'bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 shadow-[0_4px_20px_rgba(6,182,212,0.1)]' 
      : 'text-slate-600 hover:text-cyan-400 hover:bg-white/[0.02]'
    }`}
  >
    <div className={`${active ? 'scale-110' : 'group-hover:scale-110'} transition-transform`}>{icon}</div>
    <span className="text-[10px] font-black tracking-widest uppercase">{label}</span>
  </button>
);

const HUDItem = ({ label, value, color }) => (
  <div className="flex flex-col min-w-[90px]">
    <span className="text-[8px] text-slate-700 font-black tracking-widest uppercase mb-0.5">{label}</span>
    <span className={`text-[10px] font-black italic tracking-tighter ${color}`}>{value}</span>
  </div>
);

const StatRow = ({ label, value, color }) => (
  <div className="flex justify-between items-center py-1.5 border-b border-white/[0.02] last:border-0">
    <span className="text-slate-600 font-bold text-[8px] uppercase tracking-tighter">{label}</span>
    <span className={`font-black text-[10px] ${color}`}>{value}</span>
  </div>
);

const InputGroup = ({ label, value, onChange, color = "text-cyan-400" }) => (
  <div className="space-y-1.5">
    <label className="text-[9px] text-slate-600 font-black uppercase pl-1">{label}</label>
    <input 
      type="number" 
      value={value} 
      onChange={(e) => onChange(e.target.value)}
      className={`w-full bg-black/60 border border-white/10 rounded-xl py-3.5 px-4 ${color} outline-none focus:border-cyan-500/40 transition-all font-black shadow-inner`} 
    />
  </div>
);
